# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# =========================================================================
# Wenza Frontend — Next.js 14 Turborepo .gitignore
# Place at: ~/code/wenzaOrg/wenza/.gitignore
# =========================================================================

# ---- Dependencies ----
node_modules/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# ---- Environment & secrets ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env.production
.env.staging

# ---- Next.js build output ----
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ---- Turborepo ----
.turbo/
.turbo-cache/

# ---- Testing ----
coverage/
.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/
*.lcov

# ---- Vercel ----
.vercel/

# ---- TypeScript ----
*.tsbuildinfo

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# ---- IDE / editor ----
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.fleet/
.zed/
.vs/
*.sublime-project
*.sublime-workspace
.history/
*.code-workspace

# ---- OS noise ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Caches & tooling ----
.eslintcache
.stylelintcache
.parcel-cache/
.cache/
.temp/
.tmp/

# ---- Storybook ----
storybook-static/

# ---- Generated content ----
public/sitemap.xml
public/sitemap-*.xml
public/robots.txt.backup

# ---- Sentry ----
.sentryclirc

# ---- Local certificates (HTTPS dev) ----
*.pem
*.key
*.cert
*.crt
!**/public/certs/wenza-cert-template.svg

# ---- Content lock files for content layer tools ----
.contentlayer/

# ---- Bundle analysis ----
.next/analyze/
bundle-stats.html

# ---- Debug files ----
.vercel-debug/
.next-debug/
debug.log

# ---- Miscellaneous ----
*.swp
*.swo
*~
.grunt/
.lock-wscript

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
